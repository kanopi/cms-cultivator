{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanopi.github.io/cms-cultivator/spec/delivery-record/v1/schema.json",
  "title": "Kanopi Delivery Record (v1) — front-matter",
  "description": "Validates the YAML front-matter of a Delivery Record. The prose body is unstructured by design and is not validated here. Per-activity required keys inside `checks` are enforced by the `if/then` branches below; the same key sets are mirrored in checks/<activity_type>.json for granular, single-block validation.",
  "type": "object",
  "required": [
    "predicate_type",
    "activity_type",
    "subject",
    "assisted_by",
    "checks",
    "sign_off"
  ],
  "additionalProperties": true,
  "properties": {
    "predicate_type": {
      "type": "string",
      "description": "Versioned, resolvable predicate identifier. Resolves to the human-readable schema page on the docs site.",
      "pattern": "^https://kanopi\\.github\\.io/cms-cultivator/spec/delivery-record/v\\d+/?$"
    },
    "activity_type": {
      "type": "string",
      "enum": [
        "code",
        "frd",
        "audit",
        "discovery",
        "design-handoff",
        "strategy",
        "client-comm"
      ]
    },
    "subject": {
      "type": "object",
      "required": ["kind", "title"],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["pr", "document", "report", "figma", "message"]
        },
        "ref": { "type": "string" },
        "sha": { "type": ["string", "number"] },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "ticket": { "type": "string" },
    "scope": {
      "type": "string",
      "enum": ["feature", "fix", "chore", "milestone", "launch", "deliverable"]
    },
    "assisted_by": {
      "type": "object",
      "required": ["models"],
      "additionalProperties": true,
      "properties": {
        "models": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "checks": {
      "type": "object",
      "minProperties": 1,
      "description": "Each value is a check group (an object). Leaf values are a status (pass | fail | n/a) or an evidence string such as a CI run URL or a reviewer note. The pass/fail/n/a semantics and the waiver/justification rules are enforced by the verifier, not the schema.",
      "additionalProperties": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        }
      }
    },
    "sign_off": {
      "type": "object",
      "required": ["produced_by", "reviewed_by"],
      "additionalProperties": true,
      "properties": {
        "produced_by": { "type": "string", "minLength": 1 },
        "reviewed_by": { "type": "string", "minLength": 1 },
        "approved_by": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "activity_type": { "const": "code" } } },
      "then": {
        "properties": {
          "checks": {
            "required": ["standards", "tests", "audits", "review"]
          }
        }
      }
    },
    {
      "if": { "properties": { "activity_type": { "const": "frd" } } },
      "then": {
        "properties": {
          "checks": {
            "required": [
              "sow_alignment",
              "hour_total_vs_cap",
              "completeness",
              "stakeholder_review"
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "activity_type": { "const": "audit" } } },
      "then": {
        "properties": {
          "checks": {
            "required": [
              "methodology",
              "sample_size",
              "findings_verified",
              "severity_rubric"
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "activity_type": { "const": "discovery" } } },
      "then": {
        "properties": {
          "checks": {
            "required": [
              "sources_cited",
              "sample_size",
              "bias_check",
              "stakeholder_review"
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "activity_type": { "const": "design-handoff" } } },
      "then": {
        "properties": {
          "checks": {
            "required": [
              "goals_kpis",
              "audiences",
              "journeys",
              "figma_urls",
              "cd_review"
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "activity_type": { "const": "strategy" } } },
      "then": {
        "properties": {
          "checks": {
            "required": [
              "sources_grounded",
              "recommendations_defensible",
              "alternatives_considered"
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "activity_type": { "const": "client-comm" } } },
      "then": {
        "properties": {
          "checks": {
            "required": [
              "facts_verified",
              "tone_reviewed",
              "no_unauthorized_commitments"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "scope": { "enum": ["launch", "deliverable"] } },
        "required": ["scope"]
      },
      "then": {
        "properties": {
          "sign_off": { "required": ["produced_by", "reviewed_by", "approved_by"] }
        }
      }
    }
  ]
}
