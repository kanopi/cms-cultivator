{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanopi.github.io/cms-cultivator/spec/delivery-record/v1/checks/audit.json",
  "title": "Delivery Record checks — audit",
  "description": "Constrains the `checks` block for activity_type: audit. Subject kind: report. Sign-off roles: Specialist, Tech Lead.",
  "type": "object",
  "required": ["methodology", "sample_size", "findings_verified", "severity_rubric"],
  "additionalProperties": { "$ref": "#/$defs/checkGroup" },
  "properties": {
    "methodology": { "$ref": "#/$defs/checkGroup" },
    "sample_size": { "$ref": "#/$defs/checkGroup" },
    "findings_verified": { "$ref": "#/$defs/checkGroup" },
    "severity_rubric": { "$ref": "#/$defs/checkGroup" }
  },
  "$defs": {
    "checkGroup": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    }
  }
}
