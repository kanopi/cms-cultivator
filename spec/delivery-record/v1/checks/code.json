{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanopi.github.io/cms-cultivator/spec/delivery-record/v1/checks/code.json",
  "title": "Delivery Record checks — code",
  "description": "Constrains the `checks` block for activity_type: code. Subject kind: pr. Sign-off roles: Developer, Tech Lead.",
  "type": "object",
  "required": ["standards", "tests", "audits", "review"],
  "additionalProperties": { "$ref": "#/$defs/checkGroup" },
  "properties": {
    "standards": { "$ref": "#/$defs/checkGroup" },
    "tests": { "$ref": "#/$defs/checkGroup" },
    "audits": { "$ref": "#/$defs/checkGroup" },
    "review": { "$ref": "#/$defs/checkGroup" }
  },
  "$defs": {
    "checkGroup": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    }
  }
}
