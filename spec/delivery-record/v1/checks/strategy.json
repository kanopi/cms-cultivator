{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanopi.github.io/cms-cultivator/spec/delivery-record/v1/checks/strategy.json",
  "title": "Delivery Record checks — strategy",
  "description": "Constrains the `checks` block for activity_type: strategy. Subject kind: document. Sign-off roles: Strategist, Account.",
  "type": "object",
  "required": ["sources_grounded", "recommendations_defensible", "alternatives_considered"],
  "additionalProperties": { "$ref": "#/$defs/checkGroup" },
  "properties": {
    "sources_grounded": { "$ref": "#/$defs/checkGroup" },
    "recommendations_defensible": { "$ref": "#/$defs/checkGroup" },
    "alternatives_considered": { "$ref": "#/$defs/checkGroup" }
  },
  "$defs": {
    "checkGroup": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    }
  }
}
