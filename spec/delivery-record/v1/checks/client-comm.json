{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanopi.github.io/cms-cultivator/spec/delivery-record/v1/checks/client-comm.json",
  "title": "Delivery Record checks — client-comm",
  "description": "Constrains the `checks` block for activity_type: client-comm. Subject kind: message. Sign-off roles: PM, Account.",
  "type": "object",
  "required": ["facts_verified", "tone_reviewed", "no_unauthorized_commitments"],
  "additionalProperties": { "$ref": "#/$defs/checkGroup" },
  "properties": {
    "facts_verified": { "$ref": "#/$defs/checkGroup" },
    "tone_reviewed": { "$ref": "#/$defs/checkGroup" },
    "no_unauthorized_commitments": { "$ref": "#/$defs/checkGroup" }
  },
  "$defs": {
    "checkGroup": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    }
  }
}
