{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kanopi.github.io/cms-cultivator/spec/delivery-record/v1/checks/design-handoff.json",
  "title": "Delivery Record checks — design-handoff",
  "description": "Constrains the `checks` block for activity_type: design-handoff. Subject kind: document. Sign-off roles: Strategist, Designer, Tech Lead.",
  "type": "object",
  "required": ["goals_kpis", "audiences", "journeys", "figma_urls", "cd_review"],
  "additionalProperties": { "$ref": "#/$defs/checkGroup" },
  "properties": {
    "goals_kpis": { "$ref": "#/$defs/checkGroup" },
    "audiences": { "$ref": "#/$defs/checkGroup" },
    "journeys": { "$ref": "#/$defs/checkGroup" },
    "figma_urls": { "$ref": "#/$defs/checkGroup" },
    "cd_review": { "$ref": "#/$defs/checkGroup" }
  },
  "$defs": {
    "checkGroup": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    }
  }
}
